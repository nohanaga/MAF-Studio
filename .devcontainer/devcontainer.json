{
  "name": "MAF Studio",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11",

  "features": {
    "ghcr.io/devcontainers/features/azure-cli:1": {}
  },

  "postCreateCommand": "bash .devcontainer/postCreate.sh",

  "forwardPorts": [8000, 8001],
  "portsAttributes": {
    "8000": {
      "label": "MAF Studio",
      "onAutoForward": "openBrowser"
    },
    "8001": {
      "label": "Demo CRM App",
      "onAutoForward": "notify"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": false
      }
    }
  },

  "secrets": {
    "OPENAI_API_KEY": {
      "description": "OpenAI API key (OpenAI Responses プロバイダーを使う場合)"
    },
    "AZURE_OPENAI_API_KEY": {
      "description": "Azure OpenAI API key"
    },
    "AZURE_OPENAI_ENDPOINT": {
      "description": "Azure OpenAI エンドポイント (例: https://YOUR-RESOURCE.openai.azure.com/openai/v1)"
    },
    "AZURE_OPENAI_API_VERSION": {
      "description": "Azure OpenAI API バージョン (省略可)"
    },
    "AZURE_AI_PROJECT_ENDPOINT": {
      "description": "Azure AI Foundry プロジェクトエンドポイント"
    }
  }
}
